# Используем легковесный и безопасный образ Python на базе Alpine
FROM python:3.11-alpine

# Из соображений безопасности создаем системного пользователя без пароля и домашней папки
# -D означает "создать пользователя по умолчанию"
RUN adduser -D appuser

# Устанавливаем рабочую директорию
WORKDIR /app

# Копируем requirements.txt отдельно, чтобы кэшировать слои сборки
COPY requirements.txt .

# Устанавливаем зависимости
RUN pip install --no-cache-dir -r requirements.txt

# Копируем все остальные файлы проекта в рабочую директорию
COPY . .

# Меняем владельца папки /app на нашего созданного пользователя appuser
# Это нужно, чтобы Flask мог читать файлы и музыку, но не имел прав на системные папки контейнера
RUN chown -R appuser:appuser /app

# ПЕРЕКЛЮЧАЕМСЯ на безопасного пользователя. 
# Все последующие команды (включая старт приложения) будут выполняться НЕ от root
USER appuser

# Открываем порт 5000
EXPOSE 5000

# Запускаем приложение
# Вместо python app.py запускаем gunicorn
# -w 4 означает создать 4 рабочих процесса
# -b 0.0.0.0:5000 — привязать к порту 5000
# app:app — имя файла (app.py) и имя переменной Flask (app = Flask)
CMD ["gunicorn", "-w", "4", "-b", "0.0.0.0:5000", "app:app"]